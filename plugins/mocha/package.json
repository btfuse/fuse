{
  "name": "@btfuse/mocha",
  "version": "0.0.0",
  "description": "Mocha plugin for the Fuse framework",
  "main": "lib/api.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "lint": "npx eslint ./src",
    "build": "npm run lint && tsc --build && npm run build:unit:test:android",
    "build:unit:test:android": "webpack --mode development --config webpack.android.app.js && webpack --mode development --config webpack.android.specs.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btfuse/fuse.git"
  },
  "keywords": [
    "Fuse",
    "Breautek",
    "mocha",
    "unit",
    "test",
    "framework",
    "bdd",
    "behaviour",
    "driven",
    "development"
  ],
  "author": "norman@breautek.com",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/btfuse/fuse/issues"
  },
  "homepage": "https://github.com/btfuse/fuse#readme",
  "devDependencies": {
    "@types/chai": "5.2.2",
    "@types/mocha": "10.0.10",
    "chai": "5.2.0",
    "mocha": "11.5.0"
  },
  "peerDependencies": {
    "@btfuse/core": "^0.9.0",
    "mocha": "^11.5.0",
    "chai": "^5.2.0"
  },
  "dependencies": {
    "path": "0.12.7",
    "tslib": "2.8.1"
  }
}
